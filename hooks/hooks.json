{
  "description": "Auto-trigger wrapup before /compact, on session end, and on '/remember wrap' (with a dedup guard)",
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/wrapup-trigger.sh\" PreCompact"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/wrapup-trigger.sh\" SessionEnd"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "^/remember\\b",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/wrapup-trigger.sh\" Remember"
          }
        ]
      }
    ]
  }
}
